#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# Ghostty wallpaper picker (macOS and Linux, Bash 3.2-friendly)
# - Editable repo list: ~/.config/ghostty/wallpaper_repos.txt
# - Random repo & image selection with fallback across repos
# - Writes ~/.config/ghostty/wallpaper.conf and reloads Ghostty if running
# ============================================================

CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
GHOSTTY_DIR="$CONF_DIR/ghostty"
WALL_CONF="$GHOSTTY_DIR/wallpaper.conf"
MAIN_CONF="$GHOSTTY_DIR/config"
REPO_LIST_FILE="$GHOSTTY_DIR/wallpaper_repos.txt"
TEMP_DIR="${GHOSTTY_WALL_TEMP_DIR:-${TMPDIR:-/tmp}/anime_wallpapers}"
CURL_BIN="${CURL_BIN:-curl}"
OS_TYPE="${GHOSTTY_WALL_OS_TYPE:-$(uname)}"
OSASCRIPT_BIN="${OSASCRIPT_BIN:-/usr/bin/osascript}"

log() { printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"; }
die() { log "$*"; exit 1; }

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

urlencode_path() {
  local input="$1"
  local encoded=""
  local i char hex

  for ((i = 0; i < ${#input}; i++)); do
    char="${input:i:1}"
    case "$char" in
      [a-zA-Z0-9.~_-]|/) encoded+="$char" ;;
      *)
        printf -v hex '%%%02X' "'$char"
        encoded+="$hex"
        ;;
    esac
  done

  printf '%s' "$encoded"
}

urlencode_value() {
  local input="$1"
  local encoded=""
  local i char hex

  for ((i = 0; i < ${#input}; i++)); do
    char="${input:i:1}"
    case "$char" in
      [a-zA-Z0-9.~_-]) encoded+="$char" ;;
      *)
        printf -v hex '%%%02X' "'$char"
        encoded+="$hex"
        ;;
    esac
  done

  printf '%s' "$encoded"
}

write_repo_file_without_name() {
  local name="$1"
  local target_file="$2"
  local tmp_file="$3"

  awk -F'|' -v repo_name="$name" '
    {
      trimmed = $1
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", trimmed)
      if (trimmed != repo_name) {
        print
      }
    }
  ' "$target_file" >"$tmp_file"
}

ensure_repo_list_exists() {
  mkdir -p "$GHOSTTY_DIR"

  if [ ! -f "$REPO_LIST_FILE" ]; then
    cat >"$REPO_LIST_FILE" <<'EOF'
# name|owner/repo|branch|path
anime|ThePrimeagen/anime|master|
# Extra example:
# k1ngwalls|k1ng440/Wallpapers|master|wallpapers
EOF
    log "Created $REPO_LIST_FILE (edit it to add/remove repos)."
  fi
}

load_repo_lines() {
  awk -F'|' '
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { next }
    NF==4 {
      for (i=1;i<=NF;i++){ gsub(/^[[:space:]]+|[[:space:]]+$/, "", $i) }
      print $0
    }
  ' "$REPO_LIST_FILE" 2>/dev/null || true
}

validate_repo_line() {
  local line="$1"
  local name owner_repo branch subpath

  IFS='|' read -r name owner_repo branch subpath <<<"$line"

  [ -n "$name" ] || return 1
  printf '%s' "$name" | grep -Eq '^[A-Za-z0-9._-]+$' || return 1
  [ -n "$owner_repo" ] || return 1
  printf '%s' "$owner_repo" | grep -Eq '^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$' || return 1
  [ -n "$branch" ] || branch="main"
  printf '%s' "$branch" | grep -Eq '^[^[:cntrl:]|]+$' || return 1
  if [ -n "$subpath" ] && ! printf '%s' "$subpath" | grep -Eq '^[^[:cntrl:]|]+$'; then
    return 1
  fi
}

load_repo_candidates() {
  local line

  REPO_CANDIDATES=()
  while IFS= read -r line; do
    if validate_repo_line "$line"; then
      REPO_CANDIDATES+=("$line")
    else
      log "Skipping invalid repo entry: $line"
    fi
  done < <(load_repo_lines)

  [ "${#REPO_CANDIDATES[@]}" -gt 0 ] || die "No valid repos in $REPO_LIST_FILE"
}

select_repo_line() {
  local line="$1"

  IFS='|' read -r REPO_NAME OWNER_REPO BRANCH SUBPATH <<<"$line"
  [ -n "${BRANCH:-}" ] || BRANCH="main"
  SUBPATH="${SUBPATH:-}"
  SUBPATH="${SUBPATH#/}"
  SUBPATH="${SUBPATH%/}"

  log "Selected repo: ${REPO_NAME:-$OWNER_REPO} (branch: $BRANCH path: ${SUBPATH:-/})"
}

build_repo_api_url() {
  local api="https://api.github.com/repos/$OWNER_REPO/contents"
  [ -n "$SUBPATH" ] && api="$api/$(urlencode_path "$SUBPATH")"
  API_URL="$api?ref=$(urlencode_value "$BRANCH")"
}

curl_fetch() {
  "$CURL_BIN" --fail --silent --show-error --location --retry 3 --retry-delay 1 --connect-timeout 10 "$@"
}

curl_fetch_api() {
  local output_file="$1"
  shift

  "$CURL_BIN" --silent --show-error --location --retry 3 --retry-delay 1 --connect-timeout 10 -o "$output_file" -w '%{http_code}' "$@"
}

fetch_images_from_repo() {
  log "Fetching image list from GitHub..."

  local -a headers
  local json github_message http_code json_file

  headers=(-H "User-Agent: ghostty-wall")
  if [ -n "${GITHUB_TOKEN:-}" ]; then
    headers+=(-H "Authorization: Bearer $GITHUB_TOKEN" -H "X-GitHub-Api-Version: 2022-11-28")
  fi

  json_file="$(mktemp)"
  if ! http_code=$(curl_fetch_api "$json_file" "${headers[@]}" "$API_URL"); then
    rm -f "$json_file"
    log "Failed to contact GitHub for $API_URL"
    return 1
  fi

  json="$(< "$json_file")"
  rm -f "$json_file"

  github_message="$(printf '%s\n' "$json" | sed -nE 's/.*"message"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' | awk 'NR == 1 { print; exit }')"
  if [ "$http_code" = "404" ]; then
    log "Repo path not found: $OWNER_REPO/${SUBPATH:-}@${BRANCH}"
    return 1
  fi

  if [ "$http_code" != "200" ]; then
    if [ "$github_message" = "Not Found" ]; then
      log "Repo path not found: $OWNER_REPO/${SUBPATH:-}@${BRANCH}"
    elif [ -n "$github_message" ]; then
      log "GitHub API error for $OWNER_REPO/${SUBPATH:-}@${BRANCH}: $github_message"
    else
      log "GitHub API returned HTTP $http_code for $OWNER_REPO/${SUBPATH:-}@${BRANCH}"
    fi
    return 1
  fi

  IMAGE_URLS=()
  while IFS= read -r url; do
    IMAGE_URLS+=("$url")
  done < <(printf '%s\n' "$json" \
    | grep -oE '"download_url"\s*:\s*"[^"]+"' \
    | sed -E 's/.*"download_url"\s*:\s*"([^"]+)".*/\1/' \
    | grep -iE '\.(jpe?g|png|gif|webp)$' || true)

  if [ "${#IMAGE_URLS[@]}" -eq 0 ]; then
    log "No images found in $OWNER_REPO/${SUBPATH:-}@${BRANCH}"
    return 1
  fi

  log "Found ${#IMAGE_URLS[@]} images."
}

pick_and_download_image() {
  local idx url sel ext tmp_image

  mkdir -p "$TEMP_DIR"

  idx=$((RANDOM % ${#IMAGE_URLS[@]}))
  url="${IMAGE_URLS[$idx]}"
  sel="${url##*/}"
  ext="${sel##*.}"
  CURRENT_IMAGE="$TEMP_DIR/current_wallpaper.$ext"
  tmp_image="$TEMP_DIR/.current_wallpaper.$ext.tmp"

  log "Selected image: $sel"
  log "Downloading: $url"
  if ! curl_fetch "$url" -o "$tmp_image"; then
    rm -f "$tmp_image"
    log "Failed to download image"
    return 1
  fi

  mv "$tmp_image" "$CURRENT_IMAGE"
  log "Image ready: $CURRENT_IMAGE"
}

write_wall_conf_and_include() {
  mkdir -p "$GHOSTTY_DIR"

  cat >"$WALL_CONF" <<EOF
background-image=$CURRENT_IMAGE
background-image-fit=cover
background-image-position=center
background-image-opacity=0.1
EOF

  [ -f "$MAIN_CONF" ] || touch "$MAIN_CONF"
  if ! grep -qsE '^config-file[[:space:]]*=[[:space:]]*"?'"$WALL_CONF"'"?[[:space:]]*$' "$MAIN_CONF"; then
    printf '\nconfig-file = %s\n' "$WALL_CONF" >> "$MAIN_CONF"
    log "Added include to Ghostty main config."
  fi
}

reload_ghostty_if_running() {
  local ghostty_app

  case "$OS_TYPE" in
    Darwin)
      if ! command -v "$OSASCRIPT_BIN" >/dev/null 2>&1; then
        log "Automatic reload is unavailable: osascript not found."
        return 0
      fi

      ghostty_app="$("$OSASCRIPT_BIN" -e '
        tell application "System Events"
          set pn to name of processes
          if pn contains "Ghostty" then return "Ghostty"
          if pn contains "Ghostty Nightly" then return "Ghostty Nightly"
          return ""
        end tell' 2>/dev/null || true)"

      if [ -n "$ghostty_app" ]; then
        log "Reloading ${ghostty_app} config (Cmd+Shift+,)..."
        GHOSTTY_APP="$ghostty_app" "$OSASCRIPT_BIN" <<'OSA' 2>/dev/null || true
tell application (system attribute "GHOSTTY_APP") to activate
tell application "System Events" to keystroke "," using {command down, shift down}
OSA
      else
        log "Ghostty is not running: it will use the new wallpaper on next launch."
      fi
      ;;
    *) log "Automatic reload is only supported on macOS." ;;
  esac
}

run_once() {
  local idx line

  require_command "$CURL_BIN"
  ensure_repo_list_exists
  load_repo_candidates

  while [ "${#REPO_CANDIDATES[@]}" -gt 0 ]; do
    idx=$((RANDOM % ${#REPO_CANDIDATES[@]}))
    line="${REPO_CANDIDATES[$idx]}"
    unset 'REPO_CANDIDATES[$idx]'
    REPO_CANDIDATES=("${REPO_CANDIDATES[@]}")

    select_repo_line "$line"
    build_repo_api_url
    if fetch_images_from_repo && pick_and_download_image; then
      write_wall_conf_and_include
      reload_ghostty_if_running
      return 0
    fi

    log "Trying next configured repo..."
  done

  die "Unable to fetch a wallpaper from any configured repository"
}

cmd_list() {
  ensure_repo_list_exists
  echo "=== $REPO_LIST_FILE ==="
  cat "$REPO_LIST_FILE"
}

cmd_add() {
  ensure_repo_list_exists
  local line="${1:-}"
  local name tmp

  if [ -z "$line" ]; then
    echo "Usage: $0 --add 'name|owner/repo|branch|path'"
    exit 1
  fi

  if [ "$(printf '%s' "$line" | awk -F'|' '{print NF}')" -ne 4 ]; then
    echo "Invalid line: must have 4 '|' separated fields"
    exit 1
  fi

  if ! validate_repo_line "$line"; then
    echo "Invalid line: expected name|owner/repo|branch|path"
    exit 1
  fi

  name="${line%%|*}"
  tmp="$(mktemp)"
  write_repo_file_without_name "$name" "$REPO_LIST_FILE" "$tmp"
  mv "$tmp" "$REPO_LIST_FILE"
  printf '%s\n' "$line" >> "$REPO_LIST_FILE"
  log "Added/updated repo: $line"
}

cmd_remove() {
  ensure_repo_list_exists
  local name="${1:-}"
  local tmp

  if [ -z "$name" ]; then
    echo "Usage: $0 --remove <name>"
    exit 1
  fi

  if ! printf '%s' "$name" | grep -Eq '^[A-Za-z0-9._-]+$'; then
    echo "Invalid repo name: expected letters, numbers, dot, underscore, or hyphen"
    exit 1
  fi

  tmp="$(mktemp)"
  write_repo_file_without_name "$name" "$REPO_LIST_FILE" "$tmp"
  mv "$tmp" "$REPO_LIST_FILE"
  log "Removed (if present) repo: $name"
}

show_help() {
  cat <<EOF
Usage:
  $0                # one-off: pick repo+image and reload Ghostty on macOS
  $0 --list         # show repo list
  $0 --add "name|owner/repo|branch|path"
  $0 --remove <name>
  $0 --help

Files:
  - Repo list: $REPO_LIST_FILE
  - Ghostty config: $WALL_CONF (included in $MAIN_CONF)
  - Temp images: $TEMP_DIR
Tips:
  - Set GITHUB_TOKEN to avoid GitHub rate-limits.
EOF
}

case "${1:-}" in
  --list)   cmd_list ;;
  --add)    shift; cmd_add "${1:-}" ;;
  --remove) shift; cmd_remove "${1:-}" ;;
  --help|-h|"")
    if [ "${1:-}" = "" ]; then
      run_once
    else
      show_help
    fi
    ;;
  *) show_help; exit 1 ;;
esac
